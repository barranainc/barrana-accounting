---
import BaseLayout from './BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';

export interface Props {
  title: string;
  description: string;
  serviceTitle: string;
  tagline: string;
  deliveryApproach: string;
  whatClientsGain: string;
  includes: string[];
  forWho: string;
  pricingNote: string;
}

const {
  title,
  description,
  serviceTitle,
  tagline,
  deliveryApproach,
  whatClientsGain,
  includes,
  forWho,
  pricingNote,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="service-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol class="breadcrumb__list">
          <li class="breadcrumb__item"><a href="/">Home</a></li>
          <li class="breadcrumb__item"><a href="/services/">Services</a></li>
          <li class="breadcrumb__item" aria-current="page">{serviceTitle}</li>
        </ol>
      </nav>
      <p class="overline service-hero__overline">Service</p>
      <h1 class="service-hero__heading">{serviceTitle}</h1>
      <p class="service-hero__tagline">{tagline}</p>
    </div>
  </section>

  <!-- What this service is -->
  <section class="section service-body">
    <div class="container container--narrow">
      <div class="service-section fade-in">
        <h2>What this service is</h2>
        <slot name="what-this-is" />
      </div>

      <!-- How our process supports this service -->
      <div class="service-section service-process fade-in">
        <h2>How our process supports this service</h2>
        <p class="service-process__body">{deliveryApproach}</p>
      </div>

      <!-- What clients typically gain -->
      <div class="service-section fade-in">
        <h2>What clients typically gain</h2>
        <p>{whatClientsGain}</p>
      </div>

      <!-- What is included -->
      <div class="service-section fade-in">
        <h2>What is included</h2>
        <ul class="service-includes">
          {includes.map((item) => (
            <li class="service-includes__item">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <circle cx="9" cy="9" r="9" fill="rgba(126,15,74,0.1)"/>
                <path d="M5 9L7.5 11.5L13 6" stroke="#7E0F4A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Who this is for -->
      <div class="service-section fade-in">
        <h2>Who this is for</h2>
        <p>{forWho}</p>
      </div>

      <!-- Pricing + CTA -->
      <div class="service-pricing fade-in">
        <p class="service-pricing__note">{pricingNote}</p>
        <a href="/contact/" class="btn btn--primary btn--lg">Book a free consultation</a>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Need support with this area of your accounting?"
    body="Book a consultation to see whether Barrana Accounting Services is a fit for your business."
    cta1Label="Book a free consultation"
    cta1Href="/contact/"
    cta2Label="View all services"
    cta2Href="/services/"
  />
</BaseLayout>

<style>
  .service-hero {
    background: var(--color-dark);
    background-image: radial-gradient(circle at 80% 50%, rgba(126, 15, 74, 0.1) 0%, transparent 60%);
    padding-block: var(--space-16) var(--space-20);
  }

  .breadcrumb {
    margin-bottom: var(--space-6);
  }

  .breadcrumb__list {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .breadcrumb__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.5);
  }

  .breadcrumb__item a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .breadcrumb__item a:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .breadcrumb__item + .breadcrumb__item::before {
    content: '/';
    color: rgba(255, 255, 255, 0.3);
  }

  .breadcrumb__item[aria-current="page"] {
    color: var(--color-primary-light);
  }

  .service-hero__overline {
    color: var(--color-primary-light);
    margin-bottom: var(--space-3);
  }

  .service-hero__heading {
    color: #fff;
    margin-bottom: var(--space-4);
  }

  .service-hero__tagline {
    font-size: var(--font-size-xl);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
    max-width: 600px;
  }

  .service-body {
    background: var(--color-light);
  }

  .service-section {
    padding-bottom: var(--space-12);
    margin-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }

  .service-section:last-of-type {
    border-bottom: none;
  }

  .service-section h2 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-5);
  }

  .service-section p {
    font-size: var(--font-size-base);
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .service-section p:last-child {
    margin-bottom: 0;
  }

  .service-process {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    border: 1px solid var(--color-border);
  }

  .service-process h2 {
    margin-bottom: var(--space-4);
  }

  .service-process__body {
    font-size: var(--font-size-base);
    color: var(--color-muted);
    line-height: 1.8;
  }

  .service-includes {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .service-includes__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--font-size-base);
    color: var(--color-dark);
    line-height: 1.6;
  }

  .service-includes__item svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .service-pricing {
    background: var(--color-surface-2);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .service-pricing__note {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .service-pricing {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
