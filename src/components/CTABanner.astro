---
export interface Props {
  heading: string;
  body: string;
  cta1Label: string;
  cta1Href: string;
  cta2Label?: string;
  cta2Href?: string;
  background?: string;
}

const {
  heading,
  body,
  cta1Label,
  cta1Href,
  cta2Label,
  cta2Href,
  background = 'var(--color-primary)',
} = Astro.props;
---

<section class="cta-banner" style={`background: ${background};`}>
  <div class="cta-banner__inner container">
    <h2 class="cta-banner__heading">{heading}</h2>
    <p class="cta-banner__body">{body}</p>
    <div class="cta-banner__actions">
      <a href={cta1Href} class="btn btn--white">{cta1Label}</a>
      {cta2Label && cta2Href && (
        <a href={cta2Href} class="btn btn--outline-white">{cta2Label}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-banner {
    padding-block: var(--space-20);
  }

  .cta-banner__inner {
    text-align: center;
    max-width: 720px;
  }

  .cta-banner__heading {
    font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-4xl));
    font-weight: 700;
    color: #fff;
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .cta-banner__body {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-8);
    line-height: 1.6;
  }

  .cta-banner__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .btn--outline-white {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: 600;
    font-family: var(--font-sans);
    cursor: pointer;
    border: 2px solid rgba(255, 255, 255, 0.6);
    background: transparent;
    color: #fff;
    transition: all var(--transition-base);
    text-decoration: none;
    white-space: nowrap;
  }

  .btn--outline-white:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }
</style>
