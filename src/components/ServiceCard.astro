---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  index?: number;
}

const { title, description, href, icon, index = 0 } = Astro.props;
// Alternate icon badge: even = navy tint, odd = magenta tint
const badgeVariant = index % 2 === 0 ? 'navy' : 'magenta';
---

<a href={href} class={`service-card service-card--${badgeVariant} fade-in`}>
  {icon && (
    <div class="service-card__icon" aria-hidden="true" set:html={icon} />
  )}
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__desc">{description}</p>
  <span class="service-card__link">
    Learn more
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--b-border);
    border-radius: var(--radius-card);
    padding: 32px;
    text-decoration: none;
    transition: border-color var(--transition-base), transform var(--transition-base), box-shadow var(--transition-base);
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
  }

  .service-card::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: var(--radius-card) var(--radius-card) 0 0;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .service-card--navy::after {
    background: var(--b-navy);
  }

  .service-card--magenta::after {
    background: var(--b-magenta);
  }

  .service-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .service-card:hover::after {
    opacity: 1;
  }

  /* Icon badge */
  .service-card__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-5);
    flex-shrink: 0;
  }

  .service-card--navy .service-card__icon {
    background: rgba(40, 56, 145, 0.08);
    box-shadow: inset 0 0 0 1px rgba(40, 56, 145, 0.2);
    color: var(--b-navy);
  }

  .service-card--magenta .service-card__icon {
    background: rgba(126, 15, 74, 0.08);
    box-shadow: inset 0 0 0 1px rgba(126, 15, 74, 0.2);
    color: var(--b-magenta);
  }

  .service-card__icon svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    fill: none;
  }

  .service-card__title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--b-dark);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .service-card__desc {
    font-size: var(--font-size-sm);
    color: var(--b-grey-dark);
    line-height: 1.7;
    flex: 1;
    margin-bottom: var(--space-5);
  }

  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    transition: gap var(--transition-fast), color var(--transition-fast);
  }

  .service-card--navy .service-card__link {
    color: var(--b-navy);
  }

  .service-card--magenta .service-card__link {
    color: var(--b-magenta);
  }

  .service-card:hover .service-card__link {
    gap: 10px;
  }
</style>
