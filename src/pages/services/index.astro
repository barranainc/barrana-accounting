---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABanner from '../../components/CTABanner.astro';

const services = [
  {
    title: 'Bookkeeping',
    description: 'Recurring bookkeeping support with structured month-end workflows and CPA-reviewed oversight.',
    href: '/services/bookkeeping/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  },
  {
    title: 'Tax returns',
    description: 'Personal and corporate tax return preparation with year-round coordination and CPA review.',
    href: '/services/tax-returns/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  },
  {
    title: 'Payroll',
    description: 'Recurring payroll support including deductions, CRA remittances, T4s, ROEs, and year-end obligations.',
    href: '/services/payroll/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
  },
  {
    title: 'Corporate tax',
    description: 'T2 corporate return preparation with cleaner records and CPA review before filing.',
    href: '/services/corporate-tax/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    title: 'HST/GST filing',
    description: 'Recurring indirect tax filing support through consistent coding, review, and timely submission.',
    href: '/services/hst-gst-filing/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    title: 'Financial reporting',
    description: 'Monthly financial reporting packages to help you understand performance, cash flow, and key changes.',
    href: '/services/financial-reporting/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  },
  {
    title: 'CFO advisory',
    description: 'Higher-level financial guidance including planning, forecasting, and strategic review with your CPA.',
    href: '/services/cfo-advisory/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];
---

<BaseLayout
  title="Accounting services for Ontario businesses | Barrana Accounting Services"
  description="Bookkeeping, tax, payroll, corporate tax, HST/GST filing, financial reporting, and advisory support for Ontario businesses through CPA oversight and a more organised delivery model."
>
  <!-- Hero -->
  <section class="services-hero">
    <div class="page-orb page-orb--1" aria-hidden="true"></div>
    <div class="page-orb page-orb--2" aria-hidden="true"></div>
    <div class="container">
      <div class="services-hero__inner fade-in">
        <p class="overline">Services</p>
        <h1>Everything your business needs,<br>handled with CPA oversight.<br><span class="accent">Seven core services.</span></h1>
        <p class="services-hero__body">Bookkeeping, tax, payroll, reporting, and advisory — all under one roof, structured to work together, and reviewed by a CPA every month.</p>
        <div class="services-hero__ctas">
          <a href="/contact/" class="btn btn--primary btn--lg">Book a consultation</a>
          <a href="/how-it-works/" class="btn btn--ghost btn--lg">See how it works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="section services-grid-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">What we do</p>
        <h2>Seven services, one<br><span class="accent">coordinated relationship.</span></h2>
        <p class="section-header__body">Each service is designed to work with the others — bookkeeping feeds tax, tax informs payroll, reporting ties it all together.</p>
      </div>

      <div class="services-grid stagger-children">
        {services.map((service, i) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            href={service.href}
            icon={service.icon}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Why the full suite matters (dark) -->
  <section class="section dark-section suite-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Why it matters</p>
        <h2>Why the full suite<br><span class="accent">matters.</span></h2>
        <p class="section-header__body" style="color: rgba(255,255,255,0.65);">When accounting is fragmented across different providers, things fall through the cracks. A single relationship changes that.</p>
      </div>

      <div class="suite-grid stagger-children">
        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="glass-card__title">One relationship</h3>
          <p class="glass-card__body">One team handles your bookkeeping, taxes, payroll, and reporting. No handoffs, no gaps, no finger-pointing between providers.</p>
        </div>
        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="glass-card__title">Coordinated deadlines</h3>
          <p class="glass-card__body">Every filing and reporting deadline across all seven services is tracked and managed as part of a single recurring workflow — not reactively.</p>
        </div>
        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="glass-card__title">CPA across all work</h3>
          <p class="glass-card__body">A CPA reviews the work across every service area — not just tax. That means better quality and cleaner records across the board.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works teaser (light) -->
  <section class="section how-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">How it works</p>
        <h2>Up and running<br><span class="accent">in three steps.</span></h2>
        <p class="section-header__body">Getting started is straightforward. Most clients are fully onboarded within a week.</p>
      </div>

      <div class="steps-row stagger-children">
        <div class="step fade-in">
          <div class="step__number" aria-hidden="true">01</div>
          <div class="step__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="step__title">Consultation</h3>
          <p class="step__body">A free 20-minute call to understand your current setup, what you need, and which services fit.</p>
        </div>

        <div class="step-connector" aria-hidden="true"></div>

        <div class="step fade-in">
          <div class="step__number" aria-hidden="true">02</div>
          <div class="step__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="step__title">Setup</h3>
          <p class="step__body">We handle onboarding — software access, chart of accounts, bank feeds, and workflow configuration. No setup fees.</p>
        </div>

        <div class="step-connector" aria-hidden="true"></div>

        <div class="step fade-in">
          <div class="step__number" aria-hidden="true">03</div>
          <div class="step__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          </div>
          <h3 class="step__title">Ongoing delivery</h3>
          <p class="step__body">Recurring work runs on schedule. Books closed monthly, filings submitted on time, reporting delivered consistently.</p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Not sure which services fit your business?"
    body="Book a consultation and we will help you identify the right level of support."
    cta1Label="Book a free consultation"
    cta1Href="/contact/"
  />
</BaseLayout>

<style>
  /* ── Hero ── */
  .services-hero {
    background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 50%, #0D1235 100%);
    min-height: 60vh;
    padding-block: var(--space-20) var(--space-24);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .page-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
  }

  .page-orb--1 {
    width: 500px;
    height: 500px;
    background: rgba(40, 56, 145, 0.3);
    top: -150px;
    right: -100px;
    animation: orb 14s ease-in-out infinite;
  }

  .page-orb--2 {
    width: 350px;
    height: 350px;
    background: rgba(126, 15, 74, 0.18);
    bottom: -80px;
    left: 5%;
    animation: orbAlt 18s ease-in-out infinite;
  }

  .services-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .services-hero__inner .overline {
    display: flex;
    margin-bottom: var(--space-5);
  }

  .services-hero__inner h1 {
    color: #fff;
    margin-bottom: var(--space-5);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .services-hero__body {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.7);
    max-width: 580px;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .services-hero__ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Section header ── */
  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section-header .overline {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-4);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-header__body {
    font-size: var(--font-size-lg);
    color: var(--b-grey-dark);
  }

  /* ── Services grid ── */
  .services-grid-section {
    background: var(--b-offwhite);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  /* ── Suite section (dark) ── */
  .suite-section {
    background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 60%, #0D1235 100%);
    position: relative;
    overflow: hidden;
  }

  .suite-section .section-header h2 {
    color: #fff;
  }

  .suite-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-card);
    backdrop-filter: blur(12px);
    padding: 36px 32px;
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  .glass-card:hover {
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .glass-card__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #3447A8, #283891);
    box-shadow: 0 8px 24px rgba(40, 56, 145, 0.35);
    color: #fff;
    margin-bottom: var(--space-5);
  }

  .glass-card__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: #fff;
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .glass-card__body {
    font-size: var(--font-size-base);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.75;
  }

  /* ── How it works ── */
  .how-section {
    background: #fff;
  }

  .steps-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 0;
    align-items: start;
    max-width: 860px;
    margin-inline: auto;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-8) var(--space-4);
    background: #fff;
    border: 1px solid var(--b-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .step:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .step__number {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--b-magenta);
    margin-bottom: var(--space-4);
  }

  .step__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #3447A8, #283891);
    box-shadow: 0 8px 24px rgba(40, 56, 145, 0.35);
    color: #fff;
    margin-bottom: var(--space-5);
  }

  .step__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--b-dark);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .step__body {
    font-size: var(--font-size-sm);
    color: var(--b-grey-dark);
    line-height: 1.7;
  }

  .step-connector {
    width: 48px;
    height: 2px;
    background: linear-gradient(90deg, var(--b-navy), var(--b-magenta));
    border-radius: 2px;
    margin-top: 80px;
    opacity: 0.35;
    align-self: start;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 900px) {
    .suite-grid {
      grid-template-columns: 1fr;
    }

    .steps-row {
      grid-template-columns: 1fr;
      max-width: 420px;
    }

    .step-connector {
      width: 2px;
      height: 32px;
      margin-top: 0;
      margin-inline: auto;
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.fade-in').forEach(el => io.observe(el));
</script>
