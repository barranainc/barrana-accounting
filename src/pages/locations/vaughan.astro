---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<BaseLayout
  title="Accounting services in Vaughan, Ontario | Barrana Accounting Services"
  description="Structured bookkeeping, tax, payroll, and reporting support for Vaughan businesses — delivered remotely with CPA oversight and organised workflows."
>

  <!-- ═══════════════════════════════════════
       HERO — dark navy with animated orbs
  ═══════════════════════════════════════ -->
  <section class="loc-hero">
    <div class="loc-hero__orb loc-hero__orb--1" aria-hidden="true"></div>
    <div class="loc-hero__orb loc-hero__orb--2" aria-hidden="true"></div>

    <div class="container loc-hero__inner">
      <div class="loc-hero__content">
        <p class="overline loc-hero__overline">York Region</p>
        <h1 class="loc-hero__heading">
          Accounting services for<br>Vaughan businesses
        </h1>
        <p class="loc-hero__accent">Based in Vaughan. Built for York Region.</p>
        <p class="loc-hero__body">
          Structured bookkeeping, tax, payroll, and reporting support for Vaughan businesses — delivered remotely with CPA oversight and organised workflows.
        </p>
        <div class="loc-hero__ctas">
          <a href="/contact/" class="btn btn--white btn--lg">
            Book a free consultation →
          </a>
          <a href="/services/" class="btn btn--ghost btn--lg">View services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SERVICES — light offwhite
  ═══════════════════════════════════════ -->
  <section class="section loc-services">
    <div class="container">
      <div class="loc-section-header fade-in">
        <p class="overline">What we handle</p>
        <h2>Seven services. One CPA relationship.</h2>
      </div>
      <div class="services-grid stagger-children">

        <div class="svc-row fade-in">
          <div class="svc-row__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <div class="svc-row__body">
            <strong>Bookkeeping</strong>
            <span>Month-end processes, bank reconciliations, and CPA-reviewed oversight.</span>
          </div>
          <a href="/services/bookkeeping/" class="svc-row__link">Learn more →</a>
        </div>

        <div class="svc-row fade-in">
          <div class="svc-row__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <div class="svc-row__body">
            <strong>Tax Returns</strong>
            <span>Personal and corporate return preparation with CPA review.</span>
          </div>
          <a href="/services/tax-returns/" class="svc-row__link">Learn more →</a>
        </div>

        <div class="svc-row fade-in">
          <div class="svc-row__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <div class="svc-row__body">
            <strong>Payroll</strong>
            <span>Payroll runs, statutory deductions, and CRA remittances.</span>
          </div>
          <a href="/services/payroll/" class="svc-row__link">Learn more →</a>
        </div>

        <div class="svc-row fade-in">
          <div class="svc-row__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <div class="svc-row__body">
            <strong>Corporate Tax</strong>
            <span>T2 preparation and related schedules through an organised year-end process.</span>
          </div>
          <a href="/services/corporate-tax/" class="svc-row__link">Learn more →</a>
        </div>

        <div class="svc-row fade-in">
          <div class="svc-row__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <div class="svc-row__body">
            <strong>HST/GST Filing</strong>
            <span>Recurring indirect tax filings managed through consistent, timely submission.</span>
          </div>
          <a href="/services/hst-gst-filing/" class="svc-row__link">Learn more →</a>
        </div>

        <div class="svc-row fade-in">
          <div class="svc-row__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <div class="svc-row__body">
            <strong>Financial Reporting</strong>
            <span>Monthly financial packages for performance, cash flow, and key changes.</span>
          </div>
          <a href="/services/financial-reporting/" class="svc-row__link">Learn more →</a>
        </div>

        <div class="svc-row fade-in">
          <div class="svc-row__icon svc-row__icon--magenta" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div class="svc-row__body">
            <strong>CFO Advisory</strong>
            <span>Planning, forecasting, and strategic financial guidance for growing businesses.</span>
          </div>
          <a href="/services/cfo-advisory/" class="svc-row__link">Learn more →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       WHY — dark navy glass cards
  ═══════════════════════════════════════ -->
  <section class="section loc-why dark-section">
    <div class="loc-why__orb loc-why__orb--1" aria-hidden="true"></div>
    <div class="loc-why__orb loc-why__orb--2" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="loc-section-header loc-section-header--dark fade-in">
        <p class="overline">Why Vaughan businesses choose Barrana</p>
        <h2 style="color:#fff;">Structured accounting support,<br>delivered remotely.</h2>
      </div>
      <div class="why-cards stagger-children">

        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3>Fully remote, fully structured</h3>
          <p>No in-person requirement. Barrana delivers every service remotely through structured workflows, clear handoffs, and consistent follow-up. Location doesn't limit what we can do.</p>
        </div>

        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <h3>CPA-reviewed every month</h3>
          <p>A licensed CPA reviews every file. Not just year-end — monthly. You get professional oversight and judgment applied to your bookkeeping, reporting, and filings consistently.</p>
        </div>

        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </div>
          <h3>Cloud bookkeeping tools</h3>
          <p>We work with QuickBooks Online and Xero. Your books are always up to date, accessible, and integrated with the tools your business already uses for invoicing and banking.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       BUSINESS LANDSCAPE — light
  ═══════════════════════════════════════ -->
  <section class="section loc-landscape">
    <div class="container">
      <div class="landscape-grid">

        <div class="landscape-text fade-in">
          <p class="overline">Business landscape</p>
          <h2>Vaughan's business community</h2>
          <p>Vaughan is one of the most active business communities in York Region, with strong concentrations in construction, professional services, retail, food and beverage, and logistics. Many Vaughan businesses are at a growth stage where they need more than basic bookkeeping — they have corporate filing obligations, a small team on payroll, and an owner who wants regular financial visibility.</p>
          <p>Barrana Accounting Services is based in Vaughan and serves businesses across York Region entirely remotely. Whether you're a contractor with HST obligations, an incorporated professional service firm, or a retail business managing inventory and payroll, the accounting work has a consistent shape — and we're structured to handle it.</p>
        </div>

        <div class="landscape-facts fade-in">
          <div class="facts-card">
            <h3 class="facts-card__title">Vaughan at a glance</h3>
            <ul class="facts-list">
              <li class="facts-list__item">
                <div class="facts-list__dot" aria-hidden="true"></div>
                <div>
                  <span class="facts-list__label">Region</span>
                  <span class="facts-list__value">York Region</span>
                </div>
              </li>
              <li class="facts-list__item">
                <div class="facts-list__dot" aria-hidden="true"></div>
                <div>
                  <span class="facts-list__label">Growth</span>
                  <span class="facts-list__value">One of Ontario's fastest-growing cities</span>
                </div>
              </li>
              <li class="facts-list__item">
                <div class="facts-list__dot" aria-hidden="true"></div>
                <div>
                  <span class="facts-list__label">Business base</span>
                  <span class="facts-list__value">Strong SMB base in construction &amp; services</span>
                </div>
              </li>
              <li class="facts-list__item">
                <div class="facts-list__dot facts-list__dot--magenta" aria-hidden="true"></div>
                <div>
                  <span class="facts-list__label">Barrana</span>
                  <span class="facts-list__value">Barrana HQ location</span>
                </div>
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA BANNER
  ═══════════════════════════════════════ -->
  <CTABanner
    heading="Accounting support for Vaughan businesses"
    accentPhrase="Let's talk."
    body="Book a free consultation to see whether Barrana Accounting Services is a fit for your business."
    cta1Label="Book a free consultation"
    cta1Href="/contact/"
    cta2Label="View all services"
    cta2Href="/services/"
  />

</BaseLayout>

<style>
/* ═══════════════════════════════════════
   HERO
═══════════════════════════════════════ */
.loc-hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 50%, #0D1235 100%);
  min-height: 55vh;
  padding-block: var(--space-20) var(--space-24);
  display: flex;
  align-items: center;
}

.loc-hero__orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  pointer-events: none;
}
.loc-hero__orb--1 {
  width: 560px; height: 560px;
  background: rgba(40, 56, 145, 0.3);
  top: -180px; right: -80px;
  animation: orb 13s ease-in-out infinite;
}
.loc-hero__orb--2 {
  width: 380px; height: 380px;
  background: rgba(126, 15, 74, 0.18);
  bottom: -120px; left: 8%;
  animation: orbAlt 16s ease-in-out infinite;
}

.loc-hero__inner {
  position: relative;
  z-index: 1;
  max-width: 760px;
}

.loc-hero__overline {
  margin-bottom: var(--space-4);
}

.loc-hero__heading {
  color: #fff;
  font-size: clamp(2rem, 4.5vw, 3.25rem);
  line-height: 1.1;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-4);
}

.loc-hero__accent {
  font-family: var(--font-serif-italic);
  font-size: clamp(1.125rem, 2vw, 1.375rem);
  color: var(--b-magenta-light);
  font-style: italic;
  margin-bottom: var(--space-5);
  line-height: 1.4;
}

.loc-hero__body {
  font-size: var(--font-size-lg);
  color: rgba(255, 255, 255, 0.72);
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: var(--space-8);
}

.loc-hero__ctas {
  display: flex;
  gap: var(--space-4);
  flex-wrap: wrap;
}

/* ═══════════════════════════════════════
   SECTION HEADERS
═══════════════════════════════════════ */
.loc-section-header {
  text-align: center;
  max-width: 640px;
  margin-inline: auto;
  margin-bottom: var(--space-12);
}
.loc-section-header .overline {
  display: flex;
  justify-content: center;
  margin-bottom: var(--space-3);
}
.loc-section-header h2 {
  font-size: clamp(1.625rem, 3vw, 2.25rem);
  letter-spacing: -0.025em;
}

/* ═══════════════════════════════════════
   SERVICES GRID
═══════════════════════════════════════ */
.loc-services {
  background: var(--b-offwhite);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.svc-row {
  background: #fff;
  border: 1px solid var(--b-border);
  border-radius: 16px;
  padding: 20px 24px;
  display: flex;
  align-items: center;
  gap: var(--space-4);
  box-shadow: 0 4px 16px rgba(40, 56, 145, 0.06);
  transition: box-shadow 0.25s, transform 0.25s, border-color 0.25s;
}
.svc-row:hover {
  box-shadow: 0 8px 24px rgba(40, 56, 145, 0.12);
  transform: translateY(-4px);
  border-color: rgba(40, 56, 145, 0.15);
}

.svc-row__icon {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3447A8, #283891);
  box-shadow: 0 8px 24px rgba(40, 56, 145, 0.35);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.svc-row__icon--magenta {
  background: linear-gradient(135deg, #9B2464, #7E0F4A);
  box-shadow: 0 8px 24px rgba(126, 15, 74, 0.35);
}

.svc-row__body {
  flex: 1;
  min-width: 0;
}
.svc-row__body strong {
  display: block;
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--b-dark);
  margin-bottom: 3px;
}
.svc-row__body span {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--b-grey-dark);
  line-height: 1.5;
}

.svc-row__link {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--b-navy);
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s;
}
.svc-row__link:hover {
  color: var(--b-magenta);
}

/* ═══════════════════════════════════════
   WHY — dark glass cards
═══════════════════════════════════════ */
.loc-why {
  position: relative;
  overflow: hidden;
  background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 60%, #0D1235 100%);
}

.loc-why__orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  pointer-events: none;
}
.loc-why__orb--1 {
  width: 480px; height: 480px;
  background: rgba(126, 15, 74, 0.14);
  top: -160px; right: -60px;
  animation: orb 14s ease-in-out infinite;
}
.loc-why__orb--2 {
  width: 340px; height: 340px;
  background: rgba(40, 56, 145, 0.22);
  bottom: -100px; left: 5%;
  animation: orbAlt 17s ease-in-out infinite;
}

.why-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.glass-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  backdrop-filter: blur(12px);
  padding: 36px 32px;
  transition: background 0.25s, border-color 0.25s, transform 0.25s;
}
.glass-card:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.18);
  transform: translateY(-4px);
}

.glass-card__icon {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3447A8, #283891);
  box-shadow: 0 8px 24px rgba(40, 56, 145, 0.35);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-5);
}

.glass-card h3 {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: #fff;
  margin-bottom: var(--space-3);
  line-height: 1.25;
}

.glass-card p {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.7;
  margin: 0;
}

/* ═══════════════════════════════════════
   BUSINESS LANDSCAPE
═══════════════════════════════════════ */
.loc-landscape {
  background: #fff;
}

.landscape-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: var(--space-16);
  align-items: start;
}

.landscape-text .overline {
  margin-bottom: var(--space-3);
}

.landscape-text h2 {
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  letter-spacing: -0.025em;
  margin-bottom: var(--space-5);
}

.landscape-text p {
  font-size: var(--font-size-base);
  color: var(--b-grey-dark);
  line-height: 1.8;
  margin-bottom: var(--space-4);
}
.landscape-text p:last-child { margin-bottom: 0; }

.facts-card {
  background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 60%, #0D1235 100%);
  border-radius: 16px;
  padding: 36px 32px;
  box-shadow: 0 16px 48px rgba(40, 56, 145, 0.22);
  position: relative;
  overflow: hidden;
}
.facts-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events: none;
}

.facts-card__title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: #fff;
  margin-bottom: var(--space-6);
  position: relative;
  z-index: 1;
  letter-spacing: -0.015em;
}

.facts-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 18px;
  position: relative;
  z-index: 1;
}

.facts-list__item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
}

.facts-list__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--b-navy);
  box-shadow: 0 0 10px rgba(40, 56, 145, 0.9);
  flex-shrink: 0;
  margin-top: 4px;
}
.facts-list__dot--magenta {
  background: var(--b-magenta-light);
  box-shadow: 0 0 10px rgba(245, 182, 216, 0.8);
}

.facts-list__label {
  display: block;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 2px;
}

.facts-list__value {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.4;
}

/* ═══════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════ */
@media (max-width: 1024px) {
  .why-cards { grid-template-columns: 1fr; gap: 16px; }
  .landscape-grid { grid-template-columns: 1fr; gap: var(--space-10); }
}

@media (max-width: 768px) {
  .loc-hero { min-height: auto; padding-block: var(--space-16); }
  .services-grid { grid-template-columns: 1fr; }
  .why-cards { grid-template-columns: 1fr; }
  .landscape-grid { grid-template-columns: 1fr; }
  .loc-hero__ctas { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.fade-in').forEach(el => io.observe(el));
</script>
