---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import CTABanner from '../components/CTABanner.astro';

const faqs = [
  {
    question: 'Are there setup fees?',
    answer: 'No. Onboarding is included in your first month. We handle software setup, review your chart of accounts, and connect your bank feeds.',
  },
  {
    question: 'What if I incorporate after signing up?',
    answer: 'We will move you to the Incorporated plan when the time comes. If you are considering incorporating and want to understand the implications, your CPA can help you think through the timing.',
  },
  {
    question: 'Do you require a long-term contract?',
    answer: "No. Cancel with 30 days' notice. If you cancel mid-month, the full month applies.",
  },
  {
    question: 'What accounting software do you work with?',
    answer: 'Primarily QuickBooks Online and Xero. If you are already on one, we request accountant access. If not, we help set it up as part of onboarding.',
  },
  {
    question: 'Is a CPA actually involved in my file every month?',
    answer: 'Yes. A CPA closes your books each month, reviews financial outputs, signs off on filings, and is available for questions. The workflow layer handles the repetitive work. The CPA handles the review and judgment.',
  },
  {
    question: 'Do you work with businesses outside the GTA?',
    answer: 'Our focus is GTA and Ontario. We work remotely, so location within Ontario is not a barrier.',
  },
  {
    question: 'What is the difference between Incorporated and Growth?',
    answer: 'Incorporated covers the core needs of most owner-managed incorporated businesses. Growth is for businesses that need higher transaction volumes, larger payroll, CFO-level advisory, forecasting, or multi-entity support.',
  },
];
---

<BaseLayout
  title="Accounting pricing for Ontario businesses | Barrana Accounting Services"
  description="Explore pricing options for bookkeeping, tax, payroll, reporting, and advisory support for Ontario businesses."
>
  <!-- Hero -->
  <section class="pricing-hero">
    <div class="page-orb page-orb--1" aria-hidden="true"></div>
    <div class="page-orb page-orb--2" aria-hidden="true"></div>
    <div class="container">
      <div class="pricing-hero__inner fade-in">
        <p class="overline">Pricing</p>
        <h1>Structured support for every stage<br>of your business.<br><span class="accent">No surprises.</span></h1>
        <p class="pricing-hero__body">Clear pricing paths for businesses that need ongoing accounting support — from sole proprietors to growing incorporated companies.</p>
        <div class="pricing-hero__ctas">
          <a href="/contact/" class="btn btn--primary btn--lg">Book a free consultation</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="trust-strip">
    <div class="container">
      <ul class="trust-strip__list">
        <li class="trust-strip__item">
          <span class="trust-strip__check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          No setup fees
        </li>
        <li class="trust-strip__item">
          <span class="trust-strip__check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          No long-term contracts
        </li>
        <li class="trust-strip__item">
          <span class="trust-strip__check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          CPA reviews every file
        </li>
        <li class="trust-strip__item">
          <span class="trust-strip__check" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8L6.5 11.5L13 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          Cancel with 30 days notice
        </li>
      </ul>
    </div>
  </section>

  <!-- Pricing cards -->
  <section class="section pricing-cards-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Plans</p>
        <h2>Choose the level of support that fits.</h2>
        <p class="section-header__body">All plans are billed monthly and include CPA oversight on every file.</p>
      </div>

      <div class="pricing-page-grid stagger-children">
        <PricingCard
          label="Self-employed"
          price="Starting at $X/month"
          forWho="Sole proprietors and self-employed operators"
          includes={[
            'Bookkeeping support',
            'HST/GST filing where applicable',
            'T1 personal income tax return',
            'Year-end support',
            'Email support',
          ]}
          ctaLabel="Get started"
          ctaHref="/contact/"
        />
        <PricingCard
          label="Incorporated"
          price="Starting at $X/month"
          forWho="Owner-managed incorporated businesses"
          includes={[
            'Everything in Self-employed',
            'T2 corporate income tax return',
            'Expanded bookkeeping',
            'Payroll support (up to [X] employees)',
            'Monthly financial reporting package',
            'Semi-annual CPA review call',
            'Priority support',
          ]}
          ctaLabel="Get started"
          ctaHref="/contact/"
          featured={true}
          badge="Most popular"
        />
        <PricingCard
          label="Growth"
          price="Custom pricing"
          forWho="Higher-complexity or multi-entity businesses"
          includes={[
            'Everything in Incorporated',
            'CFO advisory support',
            'Monthly strategy conversation with CPA',
            'Cash flow forecasting',
            'Multi-entity coordination',
            'Custom workflow support',
          ]}
          ctaLabel="Book a call"
          ctaHref="/contact/"
        />
      </div>

      <p class="pricing-custom-note fade-in">
        Not sure which option fits?
        <a href="/contact/" class="btn btn--secondary">Book a free consultation</a>
      </p>
    </div>
  </section>

  <!-- What's included in every plan -->
  <section class="section dark-section included-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Every plan</p>
        <h2>What's included<br><span class="accent">in every plan.</span></h2>
        <p class="section-header__body" style="color: rgba(255,255,255,0.65);">Regardless of which tier you choose, these core standards apply to every Barrana client.</p>
      </div>

      <div class="included-grid stagger-children">
        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="glass-card__title">CPA oversight every month</h3>
          <p class="glass-card__body">A CPA closes your books, reviews outputs, and signs off on filings — every single month. Not just at year-end.</p>
        </div>
        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="glass-card__title">Structured recurring workflows</h3>
          <p class="glass-card__body">Deadlines tracked and executed with documented recurring processes — so nothing gets missed between filing periods.</p>
        </div>
        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="glass-card__title">Cloud accounting support</h3>
          <p class="glass-card__body">We work in QuickBooks Online and Xero. Onboarding, setup, and access are all handled for you at the start.</p>
        </div>
        <div class="glass-card fade-in">
          <div class="glass-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="glass-card__title">Regular communication</h3>
          <p class="glass-card__body">Questions answered, context provided, and updates delivered — not just at tax season, but throughout the year.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container container--narrow">
      <div class="section-header fade-in">
        <p class="overline">FAQ</p>
        <h2>Common questions<br><span class="accent">answered.</span></h2>
      </div>

      <div class="faq-list stagger-children">
        {faqs.map((faq, i) => (
          <details class="faq-item fade-in" id={`faq-${i}`}>
            <summary class="faq-item__summary">
              <span class="faq-item__question">{faq.question}</span>
              <span class="faq-item__arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>
            <div class="faq-item__body">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Questions about which option fits your business?"
    body="Book a free call and we will look at your current setup and help you identify the right level of support."
    cta1Label="Book a call"
    cta1Href="/contact/"
  />
</BaseLayout>

<style>
  /* ── Hero ── */
  .pricing-hero {
    background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 50%, #0D1235 100%);
    min-height: 60vh;
    padding-block: var(--space-20) var(--space-24);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .page-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
  }

  .page-orb--1 {
    width: 500px;
    height: 500px;
    background: rgba(40, 56, 145, 0.3);
    top: -150px;
    right: -100px;
    animation: orb 14s ease-in-out infinite;
  }

  .page-orb--2 {
    width: 350px;
    height: 350px;
    background: rgba(126, 15, 74, 0.18);
    bottom: -80px;
    left: 5%;
    animation: orbAlt 18s ease-in-out infinite;
  }

  .pricing-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }

  .pricing-hero__inner .overline {
    display: flex;
    margin-bottom: var(--space-5);
  }

  .pricing-hero__inner h1 {
    color: #fff;
    margin-bottom: var(--space-5);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .pricing-hero__body {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.7);
    max-width: 540px;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .pricing-hero__ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Trust strip ── */
  .trust-strip {
    background: #fff;
    border-bottom: 1px solid var(--b-border);
    padding-block: var(--space-5);
  }

  .trust-strip__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-6) var(--space-10);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .trust-strip__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--b-grey-dark);
    white-space: nowrap;
  }

  .trust-strip__check {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(40, 56, 145, 0.12), rgba(40, 56, 145, 0.06));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--b-navy);
    flex-shrink: 0;
  }

  /* ── Pricing cards section ── */
  .pricing-cards-section {
    background: var(--b-offwhite);
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section-header .overline {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-4);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-header__body {
    font-size: var(--font-size-lg);
    color: var(--b-grey-dark);
  }

  .pricing-page-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: start;
    margin-bottom: var(--space-10);
  }

  .pricing-custom-note {
    text-align: center;
    font-size: var(--font-size-base);
    color: var(--b-grey);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ── Included section (dark) ── */
  .included-section {
    background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 60%, #0D1235 100%);
    position: relative;
    overflow: hidden;
  }

  .included-section .section-header h2 {
    color: #fff;
  }

  .included-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-card);
    backdrop-filter: blur(12px);
    padding: 36px 32px;
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  .glass-card:hover {
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .glass-card__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #3447A8, #283891);
    box-shadow: 0 8px 24px rgba(40, 56, 145, 0.35);
    color: #fff;
    margin-bottom: var(--space-5);
  }

  .glass-card__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: #fff;
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .glass-card__body {
    font-size: var(--font-size-base);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.75;
  }

  /* ── FAQ ── */
  .faq-section {
    background: #fff;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border: 1px solid var(--b-border);
    border-bottom: none;
    background: #fff;
    transition: background var(--transition-fast);
  }

  .faq-item:first-of-type {
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }

  .faq-item:last-of-type {
    border-bottom: 1px solid var(--b-border);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
  }

  .faq-item[open] {
    background: var(--b-offwhite);
  }

  .faq-item__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-item__summary::-webkit-details-marker {
    display: none;
  }

  .faq-item__summary:hover {
    background: var(--b-offwhite);
  }

  .faq-item__question {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--b-dark);
    line-height: 1.5;
  }

  .faq-item[open] .faq-item__question {
    color: var(--b-navy);
  }

  .faq-item__arrow {
    flex-shrink: 0;
    color: var(--b-magenta);
    transition: transform var(--transition-base);
    display: flex;
    align-items: center;
  }

  .faq-item[open] .faq-item__arrow {
    transform: rotate(180deg);
  }

  .faq-item__body {
    padding: 0 var(--space-6) var(--space-5);
    border-top: 1px solid var(--b-border);
  }

  .faq-item__body p {
    font-size: var(--font-size-base);
    color: var(--b-grey-dark);
    line-height: 1.8;
    padding-top: var(--space-4);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .pricing-page-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }

    .included-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .trust-strip__list {
      gap: var(--space-4) var(--space-6);
    }

    .faq-item__summary {
      padding: var(--space-4) var(--space-4);
    }

    .faq-item__body {
      padding: 0 var(--space-4) var(--space-4);
    }
  }
</style>

<script>
  // Accordion: close others when one opens
  const faqItems = document.querySelectorAll<HTMLDetailsElement>('.faq-item');
  faqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        faqItems.forEach((other) => {
          if (other !== item && other.open) other.open = false;
        });
      }
    });
  });

  // IntersectionObserver scroll animations
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.fade-in').forEach(el => io.observe(el));
</script>
