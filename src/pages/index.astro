---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": ["AccountingService", "LocalBusiness"],
  "name": "Barrana Accounting Services",
  "url": "https://barranaaccounting.ai",
  "logo": "https://barranaaccounting.ai/favicon.svg",
  "description": "CPA-led accounting services for Canadian businesses and beyond, including bookkeeping, tax, payroll, reporting, and advisory support, delivered through a more organised workflow model.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Vaughan",
    "addressRegion": "ON",
    "addressCountry": "CA"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Canada"
  },
  "parentOrganization": {
    "@type": "Organization",
    "name": "Barrana.ai",
    "url": "https://barrana.ai"
  }
};

const services = [
  {
    title: 'Bookkeeping',
    description: 'Structured month-end processes, bank reconciliations, and CPA-reviewed oversight every month.',
    href: '/services/bookkeeping/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  },
  {
    title: 'Tax Returns',
    description: 'Personal and corporate tax return preparation with cleaner year-round coordination and CPA review.',
    href: '/services/tax-returns/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  },
  {
    title: 'Payroll',
    description: 'Support for payroll runs, statutory deductions, CRA remittances, and year-end payroll obligations.',
    href: '/services/payroll/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
  },
  {
    title: 'Corporate Tax',
    description: 'T2 preparation and related schedules handled through a more organised year-end process.',
    href: '/services/corporate-tax/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    title: 'HST/GST Filing',
    description: 'Recurring indirect tax filings managed through consistent coding, review, and timely submission.',
    href: '/services/hst-gst-filing/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    title: 'Financial Reporting',
    description: 'Monthly financial packages that help you understand performance, cash flow, and key changes.',
    href: '/services/financial-reporting/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  },
  {
    title: 'CFO Advisory',
    description: 'Higher-level financial support for businesses that need planning, forecasting, and strategic guidance.',
    href: '/services/cfo-advisory/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];

const steps = [
  {
    number: '01',
    title: 'Understand',
    body: 'We review your current setup, your accounting needs, and where the friction is today.',
  },
  {
    number: '02',
    title: 'Set up',
    body: 'We organise the right tools, access, workflows, and recurring processes for your file.',
  },
  {
    number: '03',
    title: 'Support',
    body: 'Routine work is handled through structured workflows, with technology supporting the repetitive steps. Exceptions go to your CPA.',
  },
  {
    number: '04',
    title: 'Review and deliver',
    body: 'Your CPA reviews the work, closes the books, and ensures reporting and filings go out on schedule.',
  },
];
---

<BaseLayout
  title="CPA-led accounting services for Canadian businesses | Barrana Accounting Services"
  description="Bookkeeping, tax, payroll, reporting, and advisory support for Canadian businesses and beyond, delivered through CPA oversight and AI-enabled workflows."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- ── Section 1: Hero — DARK ── -->
  <section class="hero dark-section">
    <div class="hero__inner container">
      <div class="hero__content">
        <p class="overline hero__overline">CPA-led accounting services &nbsp;·&nbsp; Canada &amp; Beyond</p>
        <h1 class="hero__heading">
          Modern accounting support<br>
          for Canadian businesses.
          <span class="accent">Less friction, more visibility.</span>
        </h1>
        <hr class="hero__rule" aria-hidden="true" />
        <p class="hero__body">
          Barrana Accounting Services provides bookkeeping, tax, payroll, reporting, and advisory support to Canadian businesses and beyond, through a more organised delivery model. A CPA leads the work, while AI-enabled workflows and Cloud Bookkeeping help reduce repetitive admin and keep your business better informed.
        </p>
        <div class="hero__ctas">
          <a href="/contact/" class="btn btn--white btn--lg">
            Book a free consultation
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M8.5 4L13 8l-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/how-it-works/" class="btn btn--ghost btn--lg">See how it works</a>
        </div>
      </div>

      <div class="hero__visual">
        <div class="trust-card trust-card--1 fade-in">
          <span class="trust-card__label">Licensed CPA</span>
          <span class="trust-card__desc">Professional review and judgment where it matters</span>
        </div>
        <div class="trust-card trust-card--2 fade-in">
          <span class="trust-card__label">Canada &amp; Beyond</span>
          <span class="trust-card__desc">Serving Canadian businesses and beyond</span>
        </div>
        <div class="trust-card trust-card--3 fade-in">
          <span class="trust-card__label">Cloud Bookkeeping</span>
          <span class="trust-card__desc">AI-enabled workflows and modern cloud tools</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Trust bar — LIGHT ── -->
  <section class="trust-bar">
    <div class="trust-bar__inner container">
      <div class="trust-bar__item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="9" fill="#0F6E56"/>
          <path d="M5 9L7.5 11.5L13 6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        CPA Professional review and judgment where it matters
      </div>
      <div class="trust-bar__item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="9" fill="#0F6E56"/>
          <path d="M5 9L7.5 11.5L13 6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Serving Canada and Beyond
      </div>
      <div class="trust-bar__item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="9" fill="#0F6E56"/>
          <path d="M5 9L7.5 11.5L13 6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Bookkeeping, tax, payroll, and reporting
      </div>
      <div class="trust-bar__item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="9" fill="#0F6E56"/>
          <path d="M5 9L7.5 11.5L13 6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        No long-term contracts
      </div>
    </div>
  </section>

  <!-- ── Section 3: Why Barrana — LIGHT ── -->
  <section class="section why-barrana">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Why Barrana</p>
        <h2>A more organised way<br>to handle accounting.</h2>
        <p class="section-header__body">Many businesses do not just need accounting work completed. They need a smoother way to manage recurring financial tasks, deadlines, and communication.</p>
      </div>

      <div class="grid-3 why-barrana__cards">
        <div class="feature-card fade-in">
          <div class="feature-card__icon feature-card__icon--navy" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <span class="feature-card__num">01</span>
          <h3>Better turnaround</h3>
          <p>Structured workflows help reduce delays and keep recurring accounting work moving on schedule.</p>
        </div>

        <div class="feature-card fade-in">
          <div class="feature-card__icon feature-card__icon--magenta" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
          </div>
          <span class="feature-card__num">02</span>
          <h3>Less admin friction</h3>
          <p>Clearer processes, better handoffs, and more consistent follow-up reduce the back-and-forth that slows business owners down.</p>
        </div>

        <div class="feature-card fade-in">
          <div class="feature-card__icon feature-card__icon--navy" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
            </svg>
          </div>
          <span class="feature-card__num">03</span>
          <h3>CPA oversight throughout</h3>
          <p>Technology supports the repetitive work, while a licensed CPA reviews key outputs and applies professional judgment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Section 4: Services — DARK ── -->
  <section class="section services-overview dark-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">What we handle</p>
        <h2 style="color:#fff;">Accounting support built around<br>how businesses actually operate.</h2>
        <p class="section-header__body" style="color:rgba(255,255,255,0.65);">From monthly bookkeeping to tax, payroll, reporting, and advisory support — Barrana covers the core financial work Canadian businesses need.</p>
      </div>

      <div class="services-grid">
        {services.map((service, i) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            href={service.href}
            icon={service.icon}
            index={i}
          />
        ))}
      </div>

      <div class="services-cta">
        <a href="/services/" class="btn btn--ghost btn--lg">
          View all services
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M8.5 4L13 8l-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Section 5: Process — LIGHT ── -->
  <section class="section process">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Our process</p>
        <h2>A clearer process from<br>setup to ongoing delivery.</h2>
      </div>

      <div class="process__steps">
        {steps.map((step, i) => (
          <div class="process__step fade-in">
            {i < steps.length - 1 && <div class="process__connector" aria-hidden="true" />}
            <span class="process__number">{step.number}</span>
            <h3 class="process__title">{step.title}</h3>
            <p class="process__body">{step.body}</p>
          </div>
        ))}
      </div>

      <div class="process__cta">
        <a href="/how-it-works/" class="btn btn--primary">
          See the full process
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M8.5 4L13 8l-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Section 6: Testimonials — DARK ── -->
  <section class="section testimonials dark-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Client feedback</p>
        <h2 style="color:#fff;">What a better accounting<br>process should feel like.</h2>
      </div>

      <div class="grid-3 testimonials__grid">
        <!-- PLACEHOLDER: Replace with real client quote before launch -->
        <div class="testimonial-card fade-in">
          <span class="testimonial-card__quote-mark" aria-hidden="true">&ldquo;</span>
          <blockquote class="testimonial-card__text">The process feels more organised and we spend much less time chasing documents or waiting for updates.</blockquote>
          <p class="testimonial-card__attribution">
            <strong>[Client name]</strong>, [Business type], [City]
          </p>
        </div>

        <!-- PLACEHOLDER: Replace with real client quote before launch -->
        <div class="testimonial-card fade-in">
          <span class="testimonial-card__quote-mark" aria-hidden="true">&ldquo;</span>
          <blockquote class="testimonial-card__text">We have much better visibility into what is due and what has been filed. It is a more dependable experience overall.</blockquote>
          <p class="testimonial-card__attribution">
            <strong>[Client name]</strong>, [Business type], [City]
          </p>
        </div>

        <!-- PLACEHOLDER: Replace with real client quote before launch -->
        <div class="testimonial-card fade-in">
          <span class="testimonial-card__quote-mark" aria-hidden="true">&ldquo;</span>
          <blockquote class="testimonial-card__text">Communication is clearer and the monthly workflow feels far less reactive than what we had before.</blockquote>
          <p class="testimonial-card__attribution">
            <strong>[Client name]</strong>, [Business type], [City]
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ── Section 8: CTA — DARK ── -->
  <CTABanner
    heading="Looking for a more organised accounting partner?"
    accentPhrase="We should talk."
    body="Book a consultation to see whether Barrana Accounting Services is a good fit for your business."
    cta1Label="Book your free consultation"
    cta1Href="/contact/"
    cta2Label="View all services"
    cta2Href="/services/"
  />

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 50%, #0D1235 100%);
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.04) 1.2px, transparent 1.2px),
      linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 50%, #0D1235 100%);
    background-size: 32px 32px, 100% 100%;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-20);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-16);
    align-items: center;
  }

  .hero__overline {
    margin-bottom: var(--space-5);
  }

  .hero__heading {
    color: #fff;
    margin-bottom: var(--space-6);
    font-size: clamp(2.5rem, 5vw, 4rem);
  }

  .hero__rule {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    margin-bottom: var(--space-6);
  }

  .hero__body {
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--font-size-lg);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 580px;
  }

  .hero__ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Trust cards (hero right column) ── */
  .hero__visual {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4);
  }

  .trust-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-card);
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    backdrop-filter: blur(8px);
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  .trust-card:hover {
    background: rgba(255,255,255,0.09);
    border-color: rgba(255,255,255,0.18);
  }

  .trust-card--1 { transform: translateX(0); }
  .trust-card--2 { transform: translateX(var(--space-8)); }
  .trust-card--3 { transform: translateX(var(--space-4)); }

  .trust-card__label {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--b-magenta-light);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .trust-card__desc {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.4;
  }

  /* ── Trust bar ── */
  .trust-bar {
    background: #fff;
    border-top: 1px solid var(--b-border);
    border-bottom: 1px solid var(--b-border);
    padding-block: var(--space-5);
  }

  .trust-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-10);
    flex-wrap: wrap;
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--b-dark);
    white-space: nowrap;
  }

  /* ── Section header ── */
  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section-header .overline {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-4);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
    line-height: 1.2;
  }

  .section-header__body {
    font-size: var(--font-size-lg);
    color: var(--b-grey-dark);
  }

  /* ── Why Barrana — light section ── */
  .why-barrana {
    background: var(--b-offwhite);
  }

  .feature-card {
    background: #fff;
    border-radius: var(--radius-card);
    padding: 36px 32px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--b-border);
    position: relative;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .feature-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .feature-card__num {
    position: absolute;
    top: 24px;
    right: 24px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--b-grey);
  }

  .feature-card__icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-5);
  }

  .feature-card__icon--navy {
    background: rgba(40, 56, 145, 0.08);
    box-shadow: inset 0 0 0 1px rgba(40, 56, 145, 0.2);
    color: var(--b-navy);
  }

  .feature-card__icon--magenta {
    background: rgba(126, 15, 74, 0.08);
    box-shadow: inset 0 0 0 1px rgba(126, 15, 74, 0.2);
    color: var(--b-magenta);
  }

  .feature-card h3 {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-3);
    color: var(--b-dark);
  }

  .feature-card p {
    font-size: var(--font-size-sm);
    color: var(--b-grey-dark);
    line-height: 1.7;
  }

  /* ── Services — dark section ── */
  .services-overview {
    background: linear-gradient(180deg, #1E2B78 0%, var(--b-navy-ink) 100%);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-bottom: var(--space-12);
  }

  .services-cta {
    text-align: center;
  }

  /* ── Process — light section ── */
  .process {
    background: var(--b-offwhite);
  }

  .process__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    position: relative;
    margin-bottom: var(--space-12);
  }

  .process__step {
    position: relative;
  }

  .process__connector {
    position: absolute;
    top: 30px;
    right: -50%;
    width: 100%;
    height: 1px;
    border-top: 1px dashed rgba(40, 56, 145, 0.25);
    z-index: 0;
  }

  .process__number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(180deg, #3447A8 0%, #283891 55%, #1E2B78 100%);
    box-shadow: 0 10px 24px rgba(40,56,145,0.4);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: #fff;
    margin-bottom: var(--space-4);
    position: relative;
    z-index: 1;
  }

  .process__step:last-child .process__number {
    background: linear-gradient(180deg, #9B2464 0%, #7E0F4A 55%, #640B3B 100%);
    box-shadow: 0 10px 24px rgba(126,15,74,0.4);
  }

  .process__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--b-dark);
