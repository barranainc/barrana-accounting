---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": ["AccountingService", "LocalBusiness"],
  "name": "Barrana Accounting Services",
  "url": "https://barranaaccounting.ai",
  "logo": "https://barranaaccounting.ai/images/logo-nav.png",
  "telephone": "+19052671246",
  "description": "CPA-led accounting services for Canadian businesses and beyond, including bookkeeping, tax, payroll, reporting, and advisory support, delivered through a more organised workflow model.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Vaughan",
    "addressRegion": "ON",
    "addressCountry": "CA"
  },
  "areaServed": { "@type": "Country", "name": "Canada" },
  "parentOrganization": {
    "@type": "Organization",
    "name": "Barrana.ai",
    "url": "https://barrana.ai"
  }
};

const services = [
  { title: 'Bookkeeping', description: 'Structured month-end processes, bank reconciliations, and CPA-reviewed oversight every month.', href: '/services/bookkeeping/', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>` },
  { title: 'Tax Returns', description: 'Personal and corporate tax return preparation with cleaner year-round coordination and CPA review.', href: '/services/tax-returns/', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>` },
  { title: 'Payroll', description: 'Support for payroll runs, statutory deductions, CRA remittances, and year-end payroll obligations.', href: '/services/payroll/', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>` },
  { title: 'Corporate Tax', description: 'T2 preparation and related schedules handled through a more organised year-end process.', href: '/services/corporate-tax/', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>` },
  { title: 'HST/GST Filing', description: 'Recurring indirect tax filings managed through consistent coding, review, and timely submission.', href: '/services/hst-gst-filing/', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>` },
  { title: 'Financial Reporting', description: 'Monthly financial packages that help you understand performance, cash flow, and key changes.', href: '/services/financial-reporting/', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>` },
  { title: 'CFO Advisory', description: 'Higher-level financial support for businesses that need planning, forecasting, and strategic guidance.', href: '/services/cfo-advisory/', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
];

const stats = [
  { number: 7, suffix: '', label: 'Core services covered' },
  { number: 5, suffix: '+', label: 'GTA cities served' },
  { number: 100, suffix: '%', label: 'CPA reviewed every file' },
  { number: 12, suffix: '/yr', label: 'Monthly reporting cycles' },
];
---

<BaseLayout
  title="CPA-led accounting services for Canadian businesses | Barrana Accounting Services"
  description="Bookkeeping, tax, payroll, reporting, and advisory support for Canadian businesses and beyond, delivered through CPA oversight and AI-enabled workflows."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- ══════════════════════════════════════════
       HERO — dark navy with animated orbs
  ══════════════════════════════════════════ -->
  <section class="hero dark-section">
    <!-- Animated gradient orbs -->
    <div class="hero__orb hero__orb--1" aria-hidden="true"></div>
    <div class="hero__orb hero__orb--2" aria-hidden="true"></div>
    <div class="hero__orb hero__orb--3" aria-hidden="true"></div>

    <div class="hero__inner container">
      <div class="hero__content">
        <p class="overline hero__overline anim-fade-up">CPA-led accounting services &nbsp;·&nbsp; Canada &amp; Beyond</p>
        <h1 class="hero__heading anim-fade-up delay-1">
          Modern accounting<br>support for Canadian<br>businesses.
          <span class="accent">Less friction, more visibility.</span>
        </h1>
        <hr class="hero__rule anim-fade-up delay-2" aria-hidden="true" />
        <p class="hero__body anim-fade-up delay-3">
          Barrana Accounting Services provides bookkeeping, tax, payroll, reporting, and advisory support to Canadian businesses and beyond, through a more organised delivery model. A CPA leads the work, while AI-enabled workflows and Cloud Bookkeeping help reduce repetitive admin and keep your business better informed.
        </p>
        <div class="hero__ctas anim-fade-up delay-4">
          <a href="/contact/" class="btn btn--white btn--lg hero__btn-primary">
            Book a free consultation
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M8.5 4L13 8l-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/how-it-works/" class="btn btn--ghost btn--lg">See how it works</a>
        </div>
      </div>

      <div class="hero__visual">
        <div class="trust-card trust-card--1 anim-fade-right delay-2">
          <div class="trust-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <div>
            <span class="trust-card__label">Licensed CPA</span>
            <span class="trust-card__desc">Professional review and judgment where it matters</span>
          </div>
        </div>
        <div class="trust-card trust-card--2 anim-fade-right delay-3">
          <div class="trust-card__icon trust-card__icon--magenta">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div>
            <span class="trust-card__label">Canada &amp; Beyond</span>
            <span class="trust-card__desc">Serving Canadian businesses and beyond</span>
          </div>
        </div>
        <div class="trust-card trust-card--3 anim-fade-right delay-4">
          <div class="trust-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <div>
            <span class="trust-card__label">Cloud Bookkeeping</span>
            <span class="trust-card__desc">AI-enabled workflows and modern cloud tools</span>
          </div>
        </div>

        <!-- Floating badge -->
        <div class="hero__badge anim-float delay-5">
          <span class="hero__badge-icon">✓</span>
          <span>No long-term contracts</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll" aria-hidden="true">
      <div class="hero__scroll-dot"></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       TRUST BAR — white strip
  ══════════════════════════════════════════ -->
  <section class="trust-bar">
    <div class="trust-bar__inner container">
      {[
        'CPA Professional review on every file',
        'Serving Canada and Beyond',
        'Bookkeeping, tax, payroll &amp; reporting',
        'No long-term contracts',
      ].map((item) => (
        <div class="trust-bar__item">
          <svg class="trust-bar__check" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="9" fill="#0F6E56"/>
            <path d="M5 9L7.5 11.5L13 6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span set:html={item} />
        </div>
      ))}
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       STATS STRIP — animated counters
  ══════════════════════════════════════════ -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid stagger-children">
        {stats.map((stat) => (
          <div class="stat-card fade-in">
            <div class="stat-card__number">
              <span class="stat-num" data-target={stat.number}>{stat.number}</span><span class="stat-suffix">{stat.suffix}</span>
            </div>
            <div class="stat-card__bar">
              <div class="stat-card__bar-fill"></div>
            </div>
            <p class="stat-card__label">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       WHY BARRANA — light offwhite
  ══════════════════════════════════════════ -->
  <section class="section why-barrana">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Why Barrana</p>
        <h2>A more organised way<br>to handle accounting.</h2>
        <p class="section-header__body">Many businesses don't just need accounting work completed — they need a smoother way to manage recurring tasks, deadlines, and communication.</p>
      </div>

      <div class="why-grid stagger-children">
        <div class="why-card fade-in">
          <div class="why-card__icon-wrap why-card__icon-wrap--navy">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <span class="why-card__num">01</span>
          <h3>Better turnaround</h3>
          <p>Structured workflows help reduce delays and keep recurring accounting work moving on schedule.</p>
          <div class="why-card__bar"><div class="why-card__bar-fill" style="width:85%"></div></div>
        </div>

        <div class="why-card fade-in">
          <div class="why-card__icon-wrap why-card__icon-wrap--magenta">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </div>
          <span class="why-card__num">02</span>
          <h3>Less admin friction</h3>
          <p>Clearer processes, better handoffs, and more consistent follow-up reduce the back-and-forth that slows business owners down.</p>
          <div class="why-card__bar"><div class="why-card__bar-fill" style="width:92%"></div></div>
        </div>

        <div class="why-card fade-in">
          <div class="why-card__icon-wrap why-card__icon-wrap--navy">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <span class="why-card__num">03</span>
          <h3>CPA oversight throughout</h3>
          <p>Technology supports the repetitive work, while a licensed CPA reviews key outputs and applies professional judgment.</p>
          <div class="why-card__bar"><div class="why-card__bar-fill" style="width:100%"></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SERVICES — dark navy
  ══════════════════════════════════════════ -->
  <section class="section services-overview dark-section">
    <!-- Orb decoration -->
    <div class="services__orb services__orb--1" aria-hidden="true"></div>
    <div class="services__orb services__orb--2" aria-hidden="true"></div>
    <div class="container" style="position:relative; z-index:1;">
      <div class="section-header fade-in">
        <p class="overline">What we handle</p>
        <h2 style="color:#fff;">Accounting support built around<br>how businesses actually operate.</h2>
        <p class="section-header__body" style="color:rgba(255,255,255,0.6);">From monthly bookkeeping to tax, payroll, reporting, and advisory — Barrana covers the core financial work Canadian businesses need.</p>
      </div>

      <div class="services-grid stagger-children">
        {services.map((service, i) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            href={service.href}
            icon={service.icon}
            index={i}
          />
        ))}
      </div>

      <div class="services-cta fade-in">
        <a href="/services/" class="btn btn--ghost btn--lg">
          View all services
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M8.5 4L13 8l-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       PROCESS — light with SVG flow diagram
  ══════════════════════════════════════════ -->
  <section class="section process">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Our process</p>
        <h2>From first call to ongoing delivery.<br><span style="color:var(--b-magenta); font-style:italic; font-family:var(--font-serif-italic); font-weight:400;">Four clear steps.</span></h2>
      </div>

      <!-- Visual flow diagram -->
      <div class="process-flow fade-in">
        <!-- SVG connecting line (desktop) -->
        <div class="process-flow__line-wrap" aria-hidden="true">
          <svg class="process-flow__svg" viewBox="0 0 900 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path class="svg-line" d="M 80 30 C 200 30, 200 30, 300 30 C 400 30, 400 30, 500 30 C 600 30, 600 30, 700 30 C 800 30, 800 30, 820 30"
              stroke="url(#processGrad)" stroke-width="2" stroke-linecap="round" stroke-dasharray="8 6"/>
            <defs>
              <linearGradient id="processGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%"   stop-color="#283891"/>
                <stop offset="100%" stop-color="#7E0F4A"/>
              </linearGradient>
            </defs>
          </svg>
        </div>

        <div class="process-steps stagger-children">
          {[
            { num: '01', title: 'Understand', body: 'We review your current setup, accounting needs, and where the friction is today.', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>`, color: 'navy' },
            { num: '02', title: 'Set up', body: 'We organise the right tools, access, workflows, and recurring processes for your file.', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>`, color: 'navy' },
            { num: '03', title: 'Support', body: 'Routine work is handled through structured workflows. Exceptions go to your CPA.', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`, color: 'navy' },
            { num: '04', title: 'Review & deliver', body: 'Your CPA reviews the work, closes the books, and ensures reporting and filings go out on schedule.', icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`, color: 'magenta' },
          ].map((step) => (
            <div class={`process-step process-step--${step.color} fade-in`}>
              <div class="process-step__circle">
                <div class="process-step__ring" aria-hidden="true"></div>
                <div class="process-step__icon" set:html={step.icon} />
              </div>
              <div class="process-step__num mono">{step.num}</div>
              <h3 class="process-step__title">{step.title}</h3>
              <p class="process-step__body">{step.body}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="process-cta fade-in">
        <a href="/how-it-works/" class="btn btn--primary btn--lg">
          See the full process
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M8.5 4L13 8l-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       WORKFLOW DIAGRAM — dark navy
  ══════════════════════════════════════════ -->
  <section class="section workflow dark-section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">How it fits together</p>
        <h2 style="color:#fff;">One organised system.<br><span class="accent">Less chasing, more clarity.</span></h2>
      </div>

      <div class="workflow-diagram fade-in">
        <div class="workflow-col">
          <div class="workflow-label workflow-label--left">Your business</div>
          <div class="workflow-items">
            {['Bank transactions', 'Receipts & invoices', 'Payroll inputs', 'CRA deadlines'].map((item) => (
              <div class="workflow-input-item">
                <span class="workflow-dot"></span>
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="workflow-center">
          <svg class="workflow-arrows" viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M 10 30 Q 100 30 190 55"  stroke="rgba(40,56,145,0.4)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
            <path d="M 10 80 Q 100 80 190 90"  stroke="rgba(40,56,145,0.5)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
            <path d="M 10 130 Q 100 130 190 125" stroke="rgba(126,15,74,0.4)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
            <path d="M 10 180 Q 100 180 190 160" stroke="rgba(126,15,74,0.4)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
          </svg>

          <div class="workflow-hub">
            <div class="workflow-hub__inner">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>Barrana</span>
              <small>CPA-led review</small>
            </div>
            <div class="workflow-hub__pulse" aria-hidden="true"></div>
          </div>

          <svg class="workflow-arrows" viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M 10 55 Q 100 30 190 30"  stroke="rgba(40,56,145,0.4)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
            <path d="M 10 90 Q 100 80 190 80"  stroke="rgba(40,56,145,0.5)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
            <path d="M 10 125 Q 100 130 190 130" stroke="rgba(126,15,74,0.4)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
            <path d="M 10 160 Q 100 180 190 180" stroke="rgba(126,15,74,0.4)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
          </svg>
        </div>

        <div class="workflow-col">
          <div class="workflow-label workflow-label--right">You receive</div>
          <div class="workflow-items">
            {['Reconciled books', 'Filed tax returns', 'CRA remittances', 'Monthly reports'].map((item) => (
              <div class="workflow-output-item">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7l3.5 3.5 5.5-7" stroke="#F5B6D8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       TESTIMONIALS — light
  ══════════════════════════════════════════ -->
  <section class="section testimonials">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Client feedback</p>
        <h2>What a better accounting<br>process should feel like.</h2>
      </div>

      <div class="testimonials-grid stagger-children">
        {[
          { quote: 'The process feels more organised and we spend much less time chasing documents or waiting for updates.', name: '[Client name]', biz: '[Business type], [City]' },
          { quote: 'We have much better visibility into what is due and what has been filed. It is a more dependable experience overall.', name: '[Client name]', biz: '[Business type], [City]' },
          { quote: 'Communication is clearer and the monthly workflow feels far less reactive than what we had before.', name: '[Client name]', biz: '[Business type], [City]' },
        ].map((t) => (
          <div class="testimonial-card fade-in">
            <div class="testimonial-card__stars" aria-label="5 stars">
              {[1,2,3,4,5].map(() => <span aria-hidden="true">★</span>)}
            </div>
            <blockquote class="testimonial-card__text">&ldquo;{t.quote}&rdquo;</blockquote>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar" aria-hidden="true">{t.name[1]}</div>
              <div>
                <strong class="testimonial-card__name">{t.name}</strong>
                <p class="testimonial-card__biz">{t.biz}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       CTA — dark navy gradient
  ══════════════════════════════════════════ -->
  <CTABanner
    heading="Looking for a more organised accounting partner?"
    accentPhrase="We should talk."
