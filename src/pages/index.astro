<!-- ══════════════════════════════════════════
     SCRIPTS — count-up, SVG line draw, bar anim
══════════════════════════════════════════ -->
<script>
  // ── Count-up animation ──────────────────
  function animateCount(el: HTMLElement) {
    const target = parseInt(el.dataset.target || '0', 10);
    const duration = 1600;
    const start = performance.now();
    const update = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(eased * target).toString();
      if (progress < 1) requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }

  // ── Stat bar animation ──────────────────
  function animateBar(card: Element) {
    const bar = card.querySelector<HTMLElement>('.stat-card__bar-fill');
    if (bar) {
      bar.style.width = '0';
      setTimeout(() => { bar.style.width = '100%'; }, 100);
    }
  }

  // ── SVG line draw ───────────────────────
  const svgLine = document.querySelector('.process-flow__svg .svg-line');

  // ── Intersection observer ───────────────
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target;

      // Count-up
      if (el.classList.contains('stat-card')) {
        const num = el.querySelector<HTMLElement>('.stat-num');
        if (num) animateCount(num);
        animateBar(el);
      }

      // SVG line
      if (el.classList.contains('process-flow__svg') && svgLine) {
        svgLine.classList.add('visible');
      }

      // Fade-in
      if (el.classList.contains('fade-in')) {
        el.classList.add('visible');
        io.unobserve(el);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in, .stat-card, .process-flow__svg').forEach(el => io.observe(el));

  // ── Why-card progress bars on scroll ───
  const barObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bar = entry.target.querySelector<HTMLElement>('.why-card__bar-fill');
        if (bar) bar.classList.add('animated');
        barObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.why-card').forEach(el => barObserver.observe(el));
</script>

