---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';

const steps = [
  {
    num: '01',
    title: 'Review and setup',
    body: 'We start by understanding your current setup, accounting software, recurring obligations, and where the friction is today. If there is a better way to structure the process, we identify it early.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>`,
    color: 'navy',
  },
  {
    num: '02',
    title: 'Organise the workflow',
    body: 'We put the right access, document flow, recurring tasks, and communication rhythm in place so the work has a clear operating structure.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    color: 'navy',
  },
  {
    num: '03',
    title: 'Support the recurring work',
    body: 'Routine accounting tasks are handled through structured workflows, with technology assisting repetitive steps where appropriate. Exceptions and items requiring judgment go to your CPA.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
    color: 'navy',
  },
  {
    num: '04',
    title: 'CPA review and delivery',
    body: 'A licensed CPA reviews key outputs, addresses exceptions, and helps ensure reporting, filings, and recurring deliverables stay on track.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    color: 'magenta',
  },
];

const clientNeeds = [
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`, text: 'Access to your accounting software or financial records' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`, text: 'Supporting documents where required' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`, text: 'Timely responses to exceptions or open questions' },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`, text: 'Context for unusual transactions or business changes' },
];

const tools = [
  { name: 'QuickBooks Online', desc: 'Cloud accounting', icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>` },
  { name: 'Xero', desc: 'Cloud accounting', icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l4-4 4 4M12 8v8"/></svg>` },
  { name: 'Stripe', desc: 'Payment processing', icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>` },
  { name: 'Shopify', desc: 'Ecommerce and POS', icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>` },
  { name: 'Square', desc: 'Payments and POS', icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/></svg>` },
  { name: 'Dext', desc: 'Receipt capture', icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>` },
  { name: 'Wagepoint', desc: 'Payroll processing', icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>` },
  { name: 'Barrana.ai tools', desc: 'Workflow automation', icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>` },
];

const outcomes = [
  {
    num: '01',
    title: 'More consistency',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    body: 'Recurring accounting work is easier to track and manage through a structured process.',
  },
  {
    num: '02',
    title: 'Less friction',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
    body: 'Clearer workflows reduce avoidable back-and-forth between clients and the accounting team.',
  },
  {
    num: '03',
    title: 'Better visibility',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    body: 'You know what is outstanding, what is due, and where things stand.',
  },
];
---

<BaseLayout
  title="How Barrana Accounting Services works | CPA-led accounting for Ontario businesses"
  description="See how Barrana Accounting Services delivers bookkeeping, tax, payroll, and reporting through CPA oversight and a more organised workflow model."
>
  <!-- ══════════════════════════════════════════
       HERO — dark navy with orbs + stats
  ══════════════════════════════════════════ -->
  <section class="hiw-hero dark-section">
    <div class="hiw-hero__orb hiw-hero__orb--1" aria-hidden="true"></div>
    <div class="hiw-hero__orb hiw-hero__orb--2" aria-hidden="true"></div>
    <div class="hiw-hero__orb hiw-hero__orb--3" aria-hidden="true"></div>

    <div class="container hiw-hero__inner">
      <p class="overline hiw-hero__overline anim-fade-up">Our process</p>
      <h1 class="hiw-hero__heading anim-fade-up delay-1">
        Four steps.
        <span class="accent">Real clarity.</span>
      </h1>
      <p class="hiw-hero__body anim-fade-up delay-2">
        Barrana Accounting Services combines professional accounting oversight with a more structured delivery model. We use organised workflows and technology to reduce repetitive admin, while a licensed CPA remains responsible for review and judgment.
      </p>

      <!-- Hero stats -->
      <div class="hiw-hero__stats anim-fade-up delay-3">
        <div class="hiw-stat">
          <span class="hiw-stat__num">4</span>
          <span class="hiw-stat__label">steps</span>
        </div>
        <div class="hiw-stat__divider" aria-hidden="true"></div>
        <div class="hiw-stat">
          <span class="hiw-stat__num">1</span>
          <span class="hiw-stat__label">CPA review</span>
        </div>
        <div class="hiw-stat__divider" aria-hidden="true"></div>
        <div class="hiw-stat">
          <span class="hiw-stat__num">Cloud</span>
          <span class="hiw-stat__label">-native workflow</span>
        </div>
      </div>

      <div class="hiw-hero__ctas anim-fade-up delay-4">
        <a href="/contact/" class="btn btn--white btn--lg">
          Book a free consultation
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M8.5 4L13 8l-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/services/" class="btn btn--ghost btn--lg">View our services</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       WHY PROCESS MATTERS — light
  ══════════════════════════════════════════ -->
  <section class="section hiw-why">
    <div class="container">
      <div class="hiw-why__grid">
        <div class="hiw-why__text fade-in">
          <p class="overline">Why it matters</p>
          <h2 class="hiw-why__heading">Why process matters in accounting</h2>
          <p>For many businesses, accounting friction does not come from one big problem. It comes from repeated small ones: unclear requests, scattered documents, inconsistent follow-up, delayed reporting, and recurring deadlines that always feel reactive.</p>
          <p>Barrana Accounting Services is built to reduce that friction. We use a more organised, digital-first process so that bookkeeping, tax, payroll, reporting, and recurring filings are easier to manage and easier to stay on top of.</p>
          <p>The goal is not to replace professional judgment. The goal is to support it with better systems.</p>
        </div>

        <div class="hiw-why__visual fade-in">
          <div class="hiw-compare">
            <!-- OLD WAY -->
            <div class="hiw-compare__panel hiw-compare__panel--old">
              <div class="hiw-compare__panel-header">
                <span class="hiw-compare__panel-icon hiw-compare__panel-icon--old">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </span>
                <span class="hiw-compare__panel-label">Old way</span>
              </div>
              <div class="hiw-compare__items">
                <div class="hiw-compare__item hiw-compare__item--bad">
                  <span class="hiw-compare__item-icon">✕</span>
                  <span>Reactive, deadline-driven</span>
                </div>
                <div class="hiw-compare__item hiw-compare__item--bad">
                  <span class="hiw-compare__item-icon">✕</span>
                  <span>Fragmented document collection</span>
                </div>
                <div class="hiw-compare__item hiw-compare__item--bad">
                  <span class="hiw-compare__item-icon">✕</span>
                  <span>Inconsistent follow-up</span>
                </div>
                <div class="hiw-compare__item hiw-compare__item--bad">
                  <span class="hiw-compare__item-icon">✕</span>
                  <span>No clear visibility into status</span>
                </div>
              </div>
            </div>

            <!-- BARRANA WAY -->
            <div class="hiw-compare__panel hiw-compare__panel--new">
              <div class="hiw-compare__panel-header">
                <span class="hiw-compare__panel-icon hiw-compare__panel-icon--new">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span class="hiw-compare__panel-label">Barrana way</span>
              </div>
              <div class="hiw-compare__items">
                <div class="hiw-compare__item hiw-compare__item--good">
                  <span class="hiw-compare__item-icon">✓</span>
                  <span>Structured, recurring cadence</span>
                </div>
                <div class="hiw-compare__item hiw-compare__item--good">
                  <span class="hiw-compare__item-icon">✓</span>
                  <span>Clear document flow and handoffs</span>
                </div>
                <div class="hiw-compare__item hiw-compare__item--good">
                  <span class="hiw-compare__item-icon">✓</span>
                  <span>Consistent communication rhythm</span>
                </div>
                <div class="hiw-compare__item hiw-compare__item--good">
                  <span class="hiw-compare__item-icon">✓</span>
                  <span>You always know where things stand</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       4-STEP PROCESS — dark navy
  ══════════════════════════════════════════ -->
  <section class="section hiw-process dark-section">
    <div class="hiw-process__orb" aria-hidden="true"></div>
    <div class="container hiw-process__inner">
      <div class="section-header fade-in">
        <p class="overline">Step by step</p>
        <h2 class="hiw-process__heading">How our service works</h2>
        <p class="hiw-process__sub">Four clear steps from first call to ongoing delivery.</p>
      </div>

      <!-- SVG connecting line (desktop) -->
      <div class="hiw-process__line-wrap" aria-hidden="true">
        <svg class="hiw-process__svg" viewBox="0 0 900 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path class="svg-line" d="M 80 30 C 200 30, 200 30, 300 30 C 400 30, 400 30, 500 30 C 600 30, 600 30, 700 30 C 800 30, 800 30, 820 30"
            stroke="url(#hiwGrad)" stroke-width="2" stroke-linecap="round" stroke-dasharray="8 6"/>
          <defs>
            <linearGradient id="hiwGrad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#283891"/>
              <stop offset="100%" stop-color="#7E0F4A"/>
            </linearGradient>
          </defs>
        </svg>
      </div>

      <div class="hiw-steps stagger-children">
        {steps.map((step) => (
          <div class={`hiw-step hiw-step--${step.color} fade-in`}>
            <div class="hiw-step__circle">
              <div class="hiw-step__ring" aria-hidden="true"></div>
              <div class="hiw-step__icon">
                <Fragment set:html={step.icon} />
              </div>
            </div>
            <div class="hiw-step__num mono">{step.num}</div>
            <h3 class="hiw-step__title">{step.title}</h3>
            <p class="hiw-step__body">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       WHAT WE NEED FROM CLIENTS — light
  ══════════════════════════════════════════ -->
  <section class="section hiw-client-needs">
    <div class="container container--narrow">
      <div class="fade-in">
        <p class="overline">Your role</p>
        <h2 class="hiw-needs__heading">What we need from clients</h2>
        <p class="hiw-needs__intro">A smoother accounting process still depends on timely inputs from your business. In most cases, we need:</p>

        <div class="hiw-needs__grid">
          {clientNeeds.map((need) => (
            <div class="hiw-need-item">
              <div class="hiw-need-item__icon">
                <Fragment set:html={need.icon} />
              </div>
              <p class="hiw-need-item__text">{need.text}</p>
            </div>
          ))}
        </div>

        <p class="hiw-needs__footer">The goal is to reduce unnecessary back-and-forth, not pretend collaboration is never required.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       TOOLS GRID — offwhite
  ══════════════════════════════════════════ -->
  <section class="section hiw-tools dark-section">
    <div class="hiw-tools__orb" aria-hidden="true"></div>
    <div class="container hiw-tools__inner">
      <div class="section-header fade-in">
        <p class="overline">Our stack</p>
        <h2 class="hiw-tools__heading">The tools that support the process</h2>
        <p class="hiw-tools__sub">We work with common accounting and operations platforms. The stack should support the service, not complicate it.</p>
      </div>

      <div class="tools-grid stagger-children">
        {tools.map((tool) => (
          <div class="tool-card fade-in">
            <div class="tool-card__icon">
              <Fragment set:html={tool.icon} />
            </div>
            <p class="tool-card__name">{tool.name}</p>
            <p class="tool-card__desc">{tool.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       OUTCOMES — light
  ══════════════════════════════════════════ -->
  <section class="section hiw-outcomes">
    <div class="container">
      <div class="section-header fade-in">
        <p class="overline">Results</p>
        <h2>What this process is designed<br><span class="accent">to improve</span></h2>
      </div>

      <div class="outcomes-row stagger-children">
        {outcomes.map((outcome) => (
          <div class="outcome-card fade-in">
            <div class="outcome-card__num mono">{outcome.num}</div>
            <div class="outcome-card__icon">
              <Fragment set:html={outcome.icon} />
            </div>
            <h3 class="outcome-card__title">{outcome.title}</h3>
            <p class="outcome-card__body">{outcome.body}</p>
            <div class="outcome-card__bar" aria-hidden="true">
              <div class="outcome-card__bar-fill"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Ready to see if this process fits your business?"
    body="Book a free consultation and we will walk through what the transition looks like for your business."
    cta1Label="Book a free consultation"
    cta1Href="/contact/"
    cta2Label="View our services"
    cta2Href="/services/"
  />
</BaseLayout>

<style>
  /* ── HERO ── */
  .hiw-hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, #1E2B78 0%, var(--b-navy-ink) 50%, #0D1235 100%);
    padding-block: var(--space-20) var(--space-24);
  }

  .hiw-hero__orb--1 {
    position: absolute;
    width: 600px;
    height: 600px;
    top: -200px;
    right: -80px;
    background: radial-gradient(circle, rgba(40,56,145,0.35) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(90px);
    animation: orb 14s ease-in-out infinite;
  }

  .hiw-hero__orb--2 {
    position: absolute;
    width: 400px;
    height: 400px;
    bottom: -120px;
    left: 5%;
    background: radial-gradient(circle, rgba(126,15,74,0.25) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(90px);
    animation: orbAlt 18s ease-in-out infinite;
  }

  .hiw-hero__orb--3 {
    position: absolute;
    width: 280px;
    height: 280px;
    top: 40%;
    left: 42%;
    background: radial-gradient(circle, rgba(40,56,145,0.15) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(70px);
    animation: orb 20s ease-in-out infinite 5s;
  }

  .hiw-hero__inner {
    position: relative;
    z-index: 1;
  }

  .hiw-hero__overline {
    margin-bottom: var(--space-5);
  }

  .hiw-hero__heading {
    color: #fff;
    max-width: 640px;
    margin-bottom: var(--space-5);
  }

  .hiw-hero__body {
    font-size: var(--font-size-lg);
    color: rgba(255,255,255,0.7);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: var(--space-10);
  }

  .hiw-hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .hiw-stat {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .hiw-stat__num {
    font-size: var(--font-size-3xl);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .hiw-stat__label {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hiw-stat__divider {
    width: 1px;
    height: 32px;
    background: rgba(255,255,255,0.15);
  }

  .hiw-hero__ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── WHY SECTION ── */
  .hiw-why {
    background: var(--b-offwhite);
  }

  .hiw-why__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .hiw-why__heading {
    margin-top: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .hiw-why__text p {
    font-size: var(--font-size-base);
    color: var(--b-grey-dark);
    line-height: 1.8;
    margin-bottom: var(--space-5);
  }

  .hiw-why__text p:last-child {
    margin-bottom: 0;
  }

  /* Comparison panels */
  .hiw-compare {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hiw-compare__panel {
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--b-border);
  }

  .hiw-compare__panel--old {
    background: #fff;
  }

  .hiw-compare__panel--new {
    background: #fff;
    border-color: var(--b-navy);
  }

  .hiw-compare__panel-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--b-border);
  }

  .hiw-compare__panel--new .hiw-compare__panel-header {
    border-color: rgba(40,56,145,0.15);
