---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": ["AccountingService", "LocalBusiness"],
  "name": "Barrana Accounting Services",
  "url": "https://barranaaccounting.ai",
  "description": "CPA-led accounting services for Ontario businesses.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Vaughan",
    "addressRegion": "ON",
    "addressCountry": "CA"
  },
  "areaServed": "Ontario"
};
---

<BaseLayout
  title="Book a consultation | Barrana Accounting Services"
  description="Book a consultation with Barrana Accounting Services to discuss bookkeeping, tax, payroll, reporting, or advisory support for your Ontario business."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- Hero -->
  <section class="contact-hero">
    <div class="container">
      <h1>Let's talk about your accounting needs</h1>
      <p class="contact-hero__body">Use this page to book a consultation or send a message if your business is looking for ongoing accounting support, a more organised process, or help with recurring financial operations.</p>
    </div>
  </section>

  <!-- Two-path contact -->
  <section class="section contact-body">
    <div class="container">
      <div class="contact-grid">
        <!-- Book a call -->
        <div class="contact-col fade-in">
          <h3 class="contact-col__heading">Book a consultation</h3>
          <p class="contact-col__intro">Choose a time that works for you. We will discuss your current setup, what kind of support you need, and whether Barrana Accounting Services is a good fit.</p>

          <!-- PLACEHOLDER: Replace with actual Calendly embed before launch -->
          <div class="calendly-placeholder">
            <p class="calendly-placeholder__title">Calendar booking</p>
            <p>Calendar booking will appear here.</p>
            <p>Replace with your Calendly embed script before launch.</p>
            <a href="https://calendly.com/[your-link]" class="btn btn--primary" target="_blank" rel="noopener">Open Calendly &rarr;</a>
          </div>
        </div>

        <!-- Contact form -->
        <div class="contact-col fade-in">
          <h3 class="contact-col__heading">Send us a message</h3>
          <p class="contact-col__intro">Prefer to write first? Share a few details and we will respond within one business day.</p>

          <form name="contact" method="POST" data-netlify="true" class="contact-form">
            <input type="hidden" name="form-name" value="contact" />

            <div class="form-group">
              <label for="name">Your name</label>
              <input type="text" id="name" name="name" required placeholder="Jane Smith" />
            </div>

            <div class="form-group">
              <label for="email">Email address</label>
              <input type="email" id="email" name="email" required placeholder="jane@company.com" />
            </div>

            <div class="form-group">
              <label for="business">Business name</label>
              <input type="text" id="business" name="business" placeholder="Smith &amp; Co. Ltd." />
            </div>

            <div class="form-group">
              <label for="incorporated">Is your business incorporated?</label>
              <select id="incorporated" name="incorporated">
                <option value="">Select...</option>
                <option>Yes</option>
                <option>No</option>
                <option>Not yet but planning to</option>
                <option>Not sure</option>
              </select>
            </div>

            <div class="form-group">
              <label for="employees">Approximate number of employees</label>
              <select id="employees" name="employees">
                <option value="">Select...</option>
                <option>Just me</option>
                <option>2 to 5</option>
                <option>6 to 15</option>
                <option>16 to 50</option>
                <option>50+</option>
              </select>
            </div>

            <div class="form-group">
              <label>Which services are you interested in?</label>
              <div class="checkbox-group">
                <label><input type="checkbox" name="services" value="bookkeeping" /> Bookkeeping</label>
                <label><input type="checkbox" name="services" value="tax-returns" /> Tax returns</label>
                <label><input type="checkbox" name="services" value="payroll" /> Payroll</label>
                <label><input type="checkbox" name="services" value="corporate-tax" /> Corporate tax</label>
                <label><input type="checkbox" name="services" value="hst-gst" /> HST/GST filing</label>
                <label><input type="checkbox" name="services" value="financial-reporting" /> Financial reporting</label>
                <label><input type="checkbox" name="services" value="cfo-advisory" /> CFO advisory</label>
              </div>
            </div>

            <div class="form-group">
              <label for="current-setup">Current accounting setup (optional)</label>
              <input type="text" id="current-setup" name="current-setup" placeholder="QuickBooks, Xero, spreadsheet-based, accountant-managed, or other" />
            </div>

            <div class="form-group">
              <label for="message">Anything else you want us to know?</label>
              <textarea id="message" name="message" rows="3" placeholder="Optional"></textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--lg">Send message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Who this is for -->
  <section class="section contact-fit" style="background: var(--color-surface);">
    <div class="container container--narrow">
      <div class="fade-in">
        <h2>Who this consultation is best for</h2>
        <p>This consultation is best for Ontario businesses looking for recurring accounting support, cleaner financial workflows, or a more modern and organised service experience.</p>
        <p class="contact-fit__note">Not sure whether you are a fit yet? Reach out anyway. We can usually tell quickly whether the service matches your needs.</p>
      </div>
    </div>
  </section>

  <!-- Contact details bar -->
  <section class="contact-details-bar">
    <div class="container">
      <div class="contact-details fade-in">
        <div class="contact-detail">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M2 6l8 5 8-5" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="2" y="4" width="16" height="12" rx="2" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <div>
            <p class="contact-detail__label">Email</p>
            <!-- PLACEHOLDER — replace before launch -->
            <a href="mailto:placeholder@barranaaccounting.ai" class="contact-detail__value">placeholder@barranaaccounting.ai</a>
          </div>
        </div>
        <div class="contact-detail">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M10 10.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z" stroke="var(--color-primary)" stroke-width="1.5"/>
            <path d="M10 2a7 7 0 0 1 7 7c0 5.25-7 11-7 11S3 14.25 3 9a7 7 0 0 1 7-7z" stroke="var(--color-primary)" stroke-width="1.5"/>
          </svg>
          <div>
            <p class="contact-detail__label">Location</p>
            <p class="contact-detail__value">Vaughan, Ontario</p>
          </div>
        </div>
        <div class="contact-detail">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="8" stroke="var(--color-primary)" stroke-width="1.5"/>
            <path d="M10 6v4l3 2" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <div>
            <p class="contact-detail__label">Service area</p>
            <p class="contact-detail__value">GTA and all of Ontario</p>
          </div>
        </div>
        <div class="contact-detail">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="8" stroke="var(--color-primary)" stroke-width="1.5"/>
            <polyline points="10 6 10 10 13 12" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <div>
            <p class="contact-detail__label">Response time</p>
            <p class="contact-detail__value">Within 1 business day</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    background: var(--color-dark);
    background-image: radial-gradient(circle at 60% 40%, rgba(126, 15, 74, 0.1) 0%, transparent 60%);
    padding-block: var(--space-16) var(--space-20);
  }

  .contact-hero h1 {
    color: #fff;
    max-width: 580px;
    margin-bottom: var(--space-5);
  }

  .contact-hero__body {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.7);
    max-width: 560px;
    line-height: 1.7;
  }

  /* Contact body */
  .contact-body {
    background: var(--color-light);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
  }

  .contact-col__heading {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-3);
  }

  .contact-col__intro {
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: var(--space-6);
  }

  /* Calendly placeholder */
  .calendly-placeholder {
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-10);
    text-align: center;
    background: var(--color-surface);
  }

  .calendly-placeholder__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: var(--space-3);
  }

  .calendly-placeholder p {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .calendly-placeholder .btn {
    margin-top: var(--space-4);
  }

  /* Form */
  .contact-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: var(--space-5);
  }

  .form-group label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-dark);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    color: var(--color-dark);
    background: var(--color-surface);
    transition: border-color var(--transition-fast);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .checkbox-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .checkbox-group label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 400;
    cursor: pointer;
  }

  .checkbox-group input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--color-primary);
    padding: 0;
    border: none;
    flex-shrink: 0;
  }

  /* Contact fit */
  .contact-fit h2 {
    margin-bottom: var(--space-4);
  }

  .contact-fit p {
    font-size: var(--font-size-base);
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .contact-fit__note {
    font-size: var(--font-size-sm) !important;
    font-style: italic;
  }

  /* Contact details bar */
  .contact-details-bar {
    background: var(--color-light);
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .contact-details {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    padding: var(--space-8);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .contact-detail {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .contact-detail svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-detail__label {
    font-size: var(--font-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    margin-bottom: var(--space-1);
  }

  .contact-detail__value {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-dark);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  a.contact-detail__value:hover {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .contact-details {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-details {
      grid-template-columns: 1fr;
    }
  }
</style>
